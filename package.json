{
  "name": "wwmm2",
  "version": "2.42.1",
  "description": "Wuthering Waves Mod Manager",
  "author": "lightninglast",
  "license": "GPL-3.0-or-later",
  "os": [
    "win32"
  ],
  "main": "./out/main/index.js",
  "scripts": {
    "build:dll-injector": "pnpm --dir native/dll-injector run build",
    "build:extractor": "pnpm --dir native/extractor run build",
    "build:mod-manager": "pnpm --dir native/mod-manager run build",
    "build:mod-manager-tools": "pnpm --dir native/mod-tools run build",
    "build:utils": "pnpm --dir native/utils run build",
    "build:native-static-glb": "pnpm --dir native/static-glb run build",
    "build:fs": "pnpm --dir native/fs run build",
    "build:native": "pnpm run build:dll-injector && pnpm run build:extractor && pnpm run build:mod-manager && pnpm run build:mod-manager-tools && pnpm run build:utils && pnpm run build:native-static-glb && pnpm run build:fs",
    "lint": "oxlint --type-aware --type-check",
    "lint:fix": "oxlint --fix",
    "fmt": "oxfmt",
    "fmt:check": "oxfmt --check",
    "typecheck": "oxlint --type-aware --type-check",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "clean": "rimraf dist",
    "build:unpack": "pnpm run clean && pnpm run build && electron-builder --dir",
    "build:win": "pnpm run clean && pnpm run build && electron-builder --win",
    "release:win": "pnpm run clean && pnpm run build && electron-builder --win --publish always"
  },
