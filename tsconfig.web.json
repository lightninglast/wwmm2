{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/renderer/src/env.d.ts",
    "src/renderer/src/**/*",
    "src/renderer/src/**/*.tsx",
    "src/preload/*.d.ts",
    "src/shared/**/*",
    "../backend/**/*"
  ],
  "references": [
    {
      "path": "../backend"
    }
  ],
  "compilerOptions": {
    "composite": false,
    "lib": ["ESNext", "DOM", "DOM.Iterable", "DOM.AsyncIterable"],
    "jsx": "react-jsx",
    "paths": {
      "@renderer/*": ["./src/renderer/src/*"],
      "@shared/*": ["./src/shared/*"],
      "@/*": ["./src/*"],
      "@main/*": ["./src/main/*"],
      "@backend/*": ["../backend/src/*"],
      "elysia": ["../backend/node_modules/elysia"],
      "@elysiajs/eden": ["../frontend/node_modules/@elysiajs/eden"]
    },
    "moduleResolution": "bundler",
    "allowImportingTsExtensions": true,
    "noEmit": true,
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false
  }
}
